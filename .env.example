# API del backend usable desde el NAVEGADOR (donar/consultar/reportar). Incluye /api.
# IMPRESCINDIBLE al publicar: si falta, el navegador pega a localhost y falla.
# También es el fallback del fetch server-side (campañas, sitemap).
NEXT_PUBLIC_API_URL=https://testnos.setperu.com/api

# Opcional: API del backend para el fetch server-side (incluye /api). Solo hace
# falta si el servidor debe usar otra URL que el navegador (p. ej. red interna).
# Si no se define, se usa NEXT_PUBLIC_API_URL.
# API_URL=https://testnos.setperu.com/api

# URL pública de este sitio Next (canonical, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# URL del app PWA (Vite) donde se realizan acciones autenticadas
NEXT_PUBLIC_APP_URL=https://nosxotrospanel.vercel.app
