# API del backend NestJS — fetch server-side (incluye /api).
# Las campañas del sitio salen de aquí (GET /campaigns): sin backend, se muestran vacías.
API_URL=http://localhost:3101/api
# API del backend usable desde el NAVEGADOR (donar/consultar/reportar). Incluye /api.
# IMPRESCINDIBLE al publicar: si falta, el navegador pega a localhost y falla.
NEXT_PUBLIC_API_URL=http://localhost:3101/api
# URL pública de este sitio Next (canonical, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=http://localhost:3001
# URL del app PWA (Vite) donde se realizan acciones autenticadas
NEXT_PUBLIC_APP_URL=http://localhost:5173
# Secreto compartido con el backend para revalidar al instante al publicar una
# campaña (POST /api/revalidate). Debe coincidir con WEB_REVALIDATE_SECRET del
# backend. Sin él, las páginas se refrescan solo por ISR (hasta 60 s).
# Server-only: nunca usar el prefijo NEXT_PUBLIC_.
REVALIDATE_SECRET=
