# API del backend NestJS — fetch server-side (incluye /api)
API_URL=http://localhost:3000/api
# API del backend usable desde el NAVEGADOR (donar/consultar/reportar). Incluye /api.
# IMPRESCINDIBLE al publicar: si falta, el navegador pega a localhost y falla.
NEXT_PUBLIC_API_URL=http://localhost:3000/api
# URL pública de este sitio Next (canonical, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=http://localhost:3001
# URL del app PWA (Vite) donde se realizan acciones autenticadas
NEXT_PUBLIC_APP_URL=http://localhost:5173
